# ============================================
# CONFIGURACIÓN DE MERCADO PAGO Y CARRITO
# ============================================

# Access Token de Mercado Pago
# TEST (para desarrollo): TEST-1234567890-abcdef-1234567890abcdef-123456789
# PRODUCCIÓN: APP-1234567890-abcdef-1234567890abcdef-123456789
# Obtener en: https://www.mercadopago.com.ar/developers/panel/credentials
MP_ACCESS_TOKEN=TEST-tu-access-token-aqui

# URL base de tu aplicación
# Desarrollo: http://localhost:3000
# Producción: https://tudominio.com
BASE_URL=http://localhost:3000

# Secret para validar webhooks (opcional, para mayor seguridad)
# Se obtiene en el panel de Mercado Pago
MP_WEBHOOK_SECRET=tu-webhook-secret-aqui

# ============================================
# OTRAS VARIABLES DE ENTORNO EXISTENTES
# ============================================

# Database
DATABASE_URL=postgresql://usuario:password@host:5432/database

# Cloudinary
CLOUD_NAME=tu-cloud-name
API_KEY=tu-api-key
API_SECRET=tu-api-secret

# Session Secret
SESSION_SECRET=tu-session-secret-super-seguro
