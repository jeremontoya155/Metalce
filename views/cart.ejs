<body>
    <!-- Incluir Navbar -->
    <%- include('partials/navbarUser') %>

        <div class="container cart-container ">
            <!-- Header del catálogo con diseño único -->
            <div class="catalog-header">
                <div class="catalog-header-content">
                    <h2 class="catalogo-title" data-i18n="catalogo_title">CATÁLOGO</h2>
                    <p class="catalog-subtitle" data-i18n="catalogo_sub">Encuentra la tecnología perfecta para ti</p>
                </div>
                <div class="catalogo-logo" style="display:flex;flex-direction:column;align-items:center;gap:10px;">
                    <img style="width: 8em;" src="<%= imagenUrl2 %>" alt="Metal-Ce Logo">
                    <a href="/catalogo/descargar" 
                       style="display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,#8B1538,#A91D47);color:#fff;text-decoration:none;padding:9px 18px;border-radius:50px;font-size:.8rem;font-weight:700;letter-spacing:.3px;box-shadow:0 4px 14px rgba(139,21,56,.3);transition:transform .2s ease,box-shadow .2s ease;"
                       onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 20px rgba(139,21,56,.45)'"
                       onmouseout="this.style.transform='';this.style.boxShadow='0 4px 14px rgba(139,21,56,.3)'"
                       title="Descargar catálogo completo en Excel">
                        📥 Descargar catálogo (.xlsx)
                    </a>
                </div>
            </div>

            <!-- Filtro fijo y sutil -->
            <div class="filter-bar-fixed">
                <div class="filter-bar-content">
                    <div class="filter-search-box">
                        <input type="text" id="quick-search" class="filter-input" placeholder="🔍 Buscar productos..." data-i18n-placeholder="search_placeholder">
                    </div>
                    <div class="filter-category-box">
                        <button class="filter-btn-hierarchy" id="toggle-hierarchy" onclick="toggleHierarchy()" data-i18n="filter_catalog">
                            🗂️ Filtrar catálogo ▾
                        </button>
                    </div>
                    <div class="filter-sort-box">
                        <select id="price-sort" class="filter-select">
                            <option value="" data-i18n="sort_price">💰 Ordenar por precio</option>
                            <option value="asc" data-i18n="sort_asc">Menor a mayor</option>
                            <option value="desc" data-i18n="sort_desc">Mayor a menor</option>
                        </select>
                    </div>
                    <button class="filter-reset-btn" id="reset-filters" data-i18n="btn_clear">✖ Limpiar</button>
                </div>
                <!-- Panel jerárquico 3 niveles -->
                <div id="hierarchy-panel" style="display:none; padding: 12px 0 4px; border-top: 1px solid rgba(139,21,56,.1); margin-top:10px;">
                    <div id="hierarchy-tree" style="display:flex; flex-wrap:wrap; gap:8px; align-items:flex-start;">
                        <%
                        // Construir estructura jerárquica
                        const famMap = new Map(); // familia => { lineas: Map(linea => [{id, nombre, icono}]) }
                        const sinFamilia = []; // categorías sin familia
                        const catMap = new Map(); // id => {nombre, icono, familia, linea}

                        products.forEach(p => {
                            if (!p.categoria_id || !p.categoria_nombre) return;
                            if (!catMap.has(p.categoria_id)) {
                                catMap.set(p.categoria_id, {
                                    id: p.categoria_id,
                                    nombre: p.categoria_nombre,
                                    icono: p.categoria_icono || '📦',
                                    familia: p.categoria_familia || null,
                                    linea: p.categoria_linea || null
                                });
                            }
                        });

                        catMap.forEach(cat => {
                            if (!cat.familia) {
                                sinFamilia.push(cat);
                                return;
                            }
                            if (!famMap.has(cat.familia)) famMap.set(cat.familia, new Map());
                            const linea = cat.linea || '—';
                            if (!famMap.get(cat.familia).has(linea)) famMap.get(cat.familia).set(linea, []);
                            famMap.get(cat.familia).get(linea).push(cat);
                        });
                        %>

                        <% famMap.forEach((lineas, familia) => { %>
                        <div class="hie-familia" data-familia="<%= familia %>">
                            <button class="hie-btn hie-familia-btn" onclick="toggleFamilia(this)" data-familia="<%= familia %>">
                                🏭 <%= familia %> <span class="hie-arrow">▾</span>
                            </button>
                            <div class="hie-lineas" style="display:none;">
                                <% lineas.forEach((cats, linea) => { %>
                                <div class="hie-linea-group">
                                    <button class="hie-btn hie-linea-btn" onclick="toggleLinea(this)" data-linea="<%= linea %>">
                                        📐 <%= linea %> <span class="hie-arrow">▾</span>
                                    </button>
                                    <div class="hie-cats" style="display:none;">
                                        <% cats.forEach(cat => { %>
                                        <button class="hie-btn hie-cat-btn" data-cat-id="<%= cat.id %>" onclick="selectHierarchyCat(this)">
                                            <%= cat.icono %> <%= cat.nombre %>
                                        </button>
                                        <% }); %>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                        </div>
                        <% }); %>

                        <% if (sinFamilia.length > 0) { %>
                        <div class="hie-familia">
                            <button class="hie-btn hie-familia-btn" onclick="toggleFamilia(this)" data-familia="">
                                📦 Sin clasificar <span class="hie-arrow">▾</span>
                            </button>
                            <div class="hie-lineas" style="display:none;">
                                <% sinFamilia.forEach(cat => { %>
                                <button class="hie-btn hie-cat-btn" data-cat-id="<%= cat.id %>" onclick="selectHierarchyCat(this)">
                                    <%= cat.icono %> <%= cat.nombre %>
                                </button>
                                <% }); %>
                            </div>
                        </div>
                        <% } %>

                        <% if (famMap.size === 0 && sinFamilia.length === 0) { %>
                        <span style="color:#999;font-size:.85rem;padding:6px;">Sin categorías definidas</span>
                        <% } %>
                    </div>
                    <% if (catMap.size > 0) { %>
                    <div style="margin-top:8px;">
                        <button class="hie-btn hie-all-btn active" id="btn-all-cats" onclick="showAllCats()" data-i18n="all_cats">
                            ✅ Todas las categorías
                        </button>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Modal de filtros -->
            <div class="filters-modal">
                <div class="filters-modal-content">
                    <h3>Filtrar productos</h3>
                    <div class="input-group mb-3">
                        <input id="search-input" type="text" class="form-control" placeholder="Buscar productos">
                    </div>
                    <label for="model-filter">Modelo</label>
                    <select id="model-filter" class="form-control mb-2">
                        <option value="">Todos los modelos</option>
                        <% let uniqueModels=new Set(); products.forEach(product=> {
                            if (product.stock > 0 && !uniqueModels.has(product.name)) {
                            uniqueModels.add(product.name); %>
                            <option value="<%= product.name %>">
                                <%= product.name %>
                            </option>
                            <% } }); %>
                    </select>
                    <label for="estado-filter">Estado</label>
                    <select id="estado-filter" class="form-control mb-2">
                        <option value="">Todos los estados</option>
                        <% let uniqueEstados=new Set(); products.forEach(product=> {
                            if (product.stock > 0 && product.estado) {
                            let estadoUpperCase = product.estado.toUpperCase();
                            if (!uniqueEstados.has(estadoUpperCase)) {
                            uniqueEstados.add(estadoUpperCase); %>
                            <option value="<%= estadoUpperCase %>">
                                <%= estadoUpperCase %>
                            </option>
                            <% } } }); %>
                    </select>
                    <label for="storage-filter">Almacenamiento (GB)</label>
                    <input id="storage-filter" type="number" class="form-control mb-2"
                        placeholder="Almacenamiento mínimo (GB)">
                    <label for="battery-filter">Batería mínima (%)</label>
                    <input id="battery-filter" type="number" class="form-control mb-2" placeholder="Batería mínima (%)">
                    <div class="buttons">
                        <button id="reset-button" class="btn btn-secondary">Resetear</button>
                        <button id="filter-button" class="btn btn-primary">Buscar</button>
                    </div>
                </div>
            </div>

            <!-- Filtro de chips/mosaico para estados -->
            <div class="estado-chips-container">
                <div class="estado-chips-wrapper">
                    <% 
                    let estadosUnicos = new Set(); 
                    products.forEach(product => {
                        if (product.stock > 0 && product.estado) {
                            estadosUnicos.add(product.estado.toUpperCase());
                        }
                    });
                    Array.from(estadosUnicos).forEach(estado => { 
                    %>
                        <button class="estado-chip" data-estado="<%= estado %>">
                            <span class="chip-icon">📱</span>
                            <span class="chip-text"><%= estado %></span>
                            <span class="chip-check">✓</span>
                        </button>
                    <% }); %>
                </div>
            </div>

            <section class="featured-products" style="min-height: 90vh;">
                <div class="products-container row" id="cart-items">
                    <% products.forEach(product=> { %>
                        <% if (product.stock> 0) { %>
                            <%- include('partials/productCard', { product: product }) %>
                                <% } %>
                                    <% }); %>
                </div>
                <!-- Mensaje de "No se encontraron coincidencias" -->
                <div id="no-results-message" class="alert alert-warning" style="display: none;">
                    No se encontraron productos que coincidan con los filtros aplicados.
                </div>

            </section>
        </div>

        <%- include('partials/footer') %>

            <!-- Scripts -->
            <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
            <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
            <script src="/js/cart.js"></script>
            <script src="/js/carrito-manager.js"></script>
            <!-- Google tag (gtag.js) -->
</body>

</html>