    <script>
        // Función para verificar si el elemento está visible en la pantalla
        function isElementInViewport(el) {
            const rect = el.getBoundingClientRect();
            return (
                rect.top <= (window.innerHeight || document.documentElement.clientHeight) &&
                rect.bottom >= 0
            );
        }

        // Función para agregar la clase 'visible' a las secciones que están en el viewport
        function handleScroll() {
            const sections = document.querySelectorAll('.fade-in-section');
            sections.forEach(section => {
                if (isElementInViewport(section)) {
                    section.classList.add('visible');
                }
            });
        }

        // Escuchar el evento de scroll para activar la animación
        window.addEventListener('scroll', handleScroll);

        // Ejecutar al cargar la página para detectar secciones visibles al inicio
        window.addEventListener('load', handleScroll);
    </script>
    <style>
        .card-img-top {
            width: 100%;
            height: auto;
        }
        /* ===== Hierarchy Filter ===== */
        .filter-btn-hierarchy {
            background: #fff;
            border: 1.5px solid rgba(139,21,56,.25);
            color: #8B1538;
            padding: 7px 16px;
            border-radius: 50px;
            font-size: .88rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s, border-color .2s;
            white-space: nowrap;
        }
        .filter-btn-hierarchy:hover, .filter-btn-hierarchy.active {
            background: #8B1538;
            color: #fff;
            border-color: #8B1538;
        }
        .hie-btn {
            background: #f7f7f7;
            border: 1.5px solid #e0e0e0;
            border-radius: 20px;
            padding: 5px 13px;
            font-size: .82rem;
            cursor: pointer;
            font-weight: 500;
            transition: all .15s;
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .hie-familia-btn { background: #fdf0f3; border-color: rgba(139,21,56,.25); color: #8B1538; font-weight: 700; }
        .hie-linea-btn { background: #e3f2fd; border-color: rgba(21,101,192,.25); color: #1565c0; }
        .hie-cat-btn { background: #f3e5f5; border-color: rgba(123,31,162,.2); color: #7b1fa2; }
        .hie-all-btn { background: #e8f5e9; border-color: rgba(46,125,50,.25); color: #2e7d32; font-weight: 700; }
        .hie-btn:hover { filter: brightness(.93); transform: translateY(-1px); }
        .hie-btn.active { filter: brightness(.82); box-shadow: 0 2px 8px rgba(0,0,0,.12); }
        .hie-familia { display: inline-block; margin-bottom: 6px; }
        .hie-lineas { padding: 6px 0 2px 12px; display:flex; flex-wrap:wrap; gap:6px; }
        .hie-linea-group { display:flex; flex-direction:column; gap:4px; }
        .hie-cats { padding: 4px 0 2px 12px; display:flex; flex-wrap:wrap; gap:4px; }
        .hie-arrow { font-size:.7rem; margin-left:2px; transition: transform .2s; }
        .hie-familia-btn.open .hie-arrow, .hie-linea-btn.open .hie-arrow { transform: rotate(180deg); }
    </style>
    <style>
        /* Admin: Selección múltiple de productos */
        .admin-select-overlay {
            position: absolute;
            top: 8px;
            left: 8px;
            z-index: 10;
            background: rgba(255,255,255,0.95);
            border-radius: 8px;
            padding: 6px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }
        .product-select-checkbox {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: #8B1538;
        }
        .product-card {
            position: relative;
        }
    </style>
