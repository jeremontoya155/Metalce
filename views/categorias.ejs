<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Categorías - Metal-Ce</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/navBar.css">
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .category-card {
            border-left: 4px solid;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            margin-bottom: 1rem;
        }
        .category-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0, 82, 163, 0.2);
        }
        .category-icon {
            font-size: 2rem;
            margin-right: 1rem;
        }
        .color-preview {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: inline-block;
            border: 2px solid #ddd;
        }
        .btn-add-category {
            background: linear-gradient(135deg, #0052A3, #00B4D8);
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 25px;
            font-weight: 600;
            transition: transform 0.3s ease;
        }
        .btn-add-category:hover {
            transform: scale(1.05);
            color: white;
        }
    </style>
</head>
<body>
    <%- include('partials/navbarUser') %>

    <div class="container" style="margin-top: 100px; padding-bottom: 40px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-primary">📂 Gestión de Categorías</h1>
            <button class="btn btn-add-category" data-toggle="modal" data-target="#addCategoryModal">
                ➕ Nueva Categoría
            </button>
        </div>

        <% if (categorias.length === 0) { %>
            <div class="alert alert-info text-center">
                <h4>No hay categorías creadas</h4>
                <p>Crea tu primera categoría para organizar tus productos</p>
            </div>
        <% } else { %>
            <div class="row">
                <% categorias.forEach(categoria => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card category-card" style="border-left-color: <%= categoria.color %>;">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <span class="category-icon"><%= categoria.icono || '📦' %></span>
                                    <div>
                                        <h5 class="mb-0"><%= categoria.nombre %></h5>
                                        <small class="text-muted"><%= categoria.descripcion || 'Sin descripción' %></small>
                                        <% if (categoria.familia || categoria.linea) { %>
                                        <div class="mt-1">
                                            <% if (categoria.familia) { %><span style="font-size:.72rem;background:#f3e5f5;color:#7b1fa2;padding:2px 8px;border-radius:10px;margin-right:4px;">🏭 <%= categoria.familia %></span><% } %>
                                            <% if (categoria.linea) { %><span style="font-size:.72rem;background:#e3f2fd;color:#1565c0;padding:2px 8px;border-radius:10px;">📐 <%= categoria.linea %></span><% } %>
                                        </div>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="color-preview" style="background-color: <%= categoria.color %>;"></span>
                                        <small class="ml-2"><%= categoria.color %></small>
                                    </div>
                                    <% 
                                      let planesCategoria = [];
                                      try { planesCategoria = JSON.parse(categoria.cuotas_planes || '[]'); } catch(e) { planesCategoria = []; }
                                      if (planesCategoria.length === 0 && categoria.cuotas_max > 0) {
                                        planesCategoria = [{cuotas: categoria.cuotas_max, interes: categoria.interes_cuotas || 0}];
                                      }
                                    %>
                                    <% if (planesCategoria.length > 0) { %>
                                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                        <% planesCategoria.forEach(plan => { %>
                                        <span style="background: #e8f5e9; color: #2e7d32; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">
                                            💳 <%= plan.cuotas %>x<% if (plan.interes > 0) { %> (<%= plan.interes %>%)<% } else { %> s/int<% } %>
                                        </span>
                                        <% }); %>
                                    </div>
                                    <% } %>
                                    <div>
                                        <a href="/edit-category/<%= categoria.id %>" class="btn btn-sm btn-primary">
                                            ✏️ Editar
                                        </a>
                                        <form action="/delete-category/<%= categoria.id %>" method="POST" style="display: inline;">
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar esta categoría?')">
                                                🗑️
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <!-- Modal Agregar Categoría se mantiene ya que es rápido para crear -->
    <div class="modal fade" id="addCategoryModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">➕ Nueva Categoría</h5>
                    <button type="button" class="close" data-dismiss="modal">
                        <span>&times;</span>
                    </button>
                </div>
                <form action="/add-category" method="POST">
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Nombre *</label>
                            <input type="text" class="form-control" name="nombre" required placeholder="Ej: Smartphones">
                        </div>
                        <div class="form-group">
                            <label>Descripción</label>
                            <textarea class="form-control" name="descripcion" rows="2" placeholder="Descripción breve de la categoría"></textarea>
                        </div>
                        <div class="form-group">
                            <label>Icono (emoji)</label>
                            <input type="text" class="form-control" name="icono" placeholder="📱 Ej: 📱, 🎧, 💻" maxlength="2">
                            <small class="text-muted">Sugerencias: 📱 💻 🎧 🔌 📲 ⌚ 🖥️ ⌨️ 🖱️</small>
                        </div>
                        <div class="form-group">
                            <label>Color</label>
                            <input type="color" class="form-control" name="color" value="#0052A3">
                        </div>
                        <div class="form-group">
                            <label>Orden</label>
                            <input type="number" class="form-control" name="orden" value="0" min="0">
                        </div>
                        <hr>
                        <h6>🏭 Jerarquía (opcional)</h6>
                        <small class="text-muted d-block mb-2">Definí a qué familia y línea pertenece esta categoría para el filtro de 3 niveles</small>
                        <div class="row">
                            <div class="col-6">
                                <div class="form-group">
                                    <label>Familia</label>
                                    <input type="text" class="form-control" name="familia" placeholder="Ej: Cocina, Industrial">
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-group">
                                    <label>Línea</label>
                                    <input type="text" class="form-control" name="linea" placeholder="Ej: Línea Verde, Premium">
                                </div>
                            </div>
                        </div>
                        <hr>
                        <h6>💳 Planes de Cuotas</h6>
                        <small class="text-muted d-block mb-2">Agregá uno o más planes de cuotas con su interés correspondiente</small>
                        <input type="hidden" name="cuotas_max" value="0">
                        <input type="hidden" name="interes_cuotas" value="0">
                        <div id="addPlanesContainer">
                            <!-- Los planes se agregan dinámicamente -->
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-success mt-2" onclick="agregarPlanAdd()">
                            ➕ Agregar plan de cuotas
                        </button>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar Categoría</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script>
        // Opciones rápidas de cuotas
        const opcionesRapidas = [3, 6, 9, 12, 18, 24];

        function crearFilaPlan(container, cuotas, interes) {
            const row = document.createElement('div');
            row.className = 'd-flex align-items-center mb-2 plan-row';
            row.innerHTML = `
                <div class="mr-2" style="flex: 1;">
                    <input type="number" class="form-control form-control-sm" name="plan_cuotas[]" 
                           value="${cuotas || ''}" min="1" max="48" placeholder="Cuotas" required>
                </div>
                <div class="mr-2" style="flex: 1;">
                    <input type="number" step="0.01" class="form-control form-control-sm" name="plan_interes[]" 
                           value="${interes || 0}" min="0" placeholder="Interés %">
                </div>
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.parentElement.remove()">
                    🗑️
                </button>
            `;
            document.getElementById(container).appendChild(row);
        }

        function agregarPlanAdd(cuotas, interes) {
            crearFilaPlan('addPlanesContainer', cuotas || '', interes || 0);
        }

        function agregarPlanesRapidosAdd() {
            opcionesRapidas.forEach(c => agregarPlanAdd(c, 0));
        }
    </script>
</body>
</html>
