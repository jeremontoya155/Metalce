<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finalizar Pedido - Metal-Ce</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/navBar.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>
        .checkout-container {
            max-width: 800px;
            margin: 100px auto 40px;
            padding: 20px;
        }
        .checkout-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            padding: 30px;
            margin-bottom: 20px;
        }
        .checkout-card h4 {
            font-weight: 700;
            color: #1d1d1f;
            margin-bottom: 20px;
        }
        .checkout-card h4 i {
            color: #0052A3;
            margin-right: 8px;
        }
        .product-item {
            display: flex;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
        }
        .product-item:last-child {
            border-bottom: none;
        }
        .product-img {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 10px;
            margin-right: 16px;
            flex-shrink: 0;
        }
        .product-info {
            flex: 1;
        }
        .product-name {
            font-weight: 600;
            color: #1d1d1f;
            margin-bottom: 2px;
            font-size: 0.95rem;
        }
        .qty-controls {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-top: 4px;
        }
        .qty-btn {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 1.5px solid #ddd;
            background: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: #555;
            transition: all 0.2s;
        }
        .qty-btn:hover {
            border-color: #0052A3;
            color: #0052A3;
        }
        .qty-btn.remove {
            color: #ff3b30;
            border-color: #ff3b30;
            font-size: 12px;
        }
        .qty-btn.remove:hover {
            background: #ff3b30;
            color: white;
        }
        .qty-value {
            font-weight: 600;
            min-width: 20px;
            text-align: center;
        }
        .product-price {
            font-weight: 700;
            color: #0052A3;
            font-size: 1rem;
            white-space: nowrap;
        }
        .total-section {
            background: #f5f5f7;
            padding: 20px;
            border-radius: 12px;
            margin-top: 20px;
        }
        .total-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 0.95rem;
            color: #555;
        }
        .total-row.final {
            font-size: 1.3em;
            font-weight: 800;
            color: #0052A3;
            border-top: 2px solid #ddd;
            padding-top: 12px;
            margin-top: 12px;
            margin-bottom: 0;
        }
        .btn-whatsapp {
            background: #25D366;
            color: white;
            border: none;
            padding: 16px;
            font-size: 1.1em;
            font-weight: 700;
            border-radius: 12px;
            width: 100%;
            margin-top: 20px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .btn-whatsapp:hover {
            background: #1DA851;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(37,211,102,0.4);
        }
        .btn-whatsapp:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        .btn-whatsapp i {
            font-size: 1.3em;
        }
        .form-control {
            border-radius: 10px;
            border: 1.5px solid #e5e5ea;
            padding: 10px 14px;
        }
        .form-control:focus {
            border-color: #0052A3;
            box-shadow: 0 0 0 3px rgba(0,82,163,0.1);
        }
        .empty-cart {
            text-align: center;
            padding: 60px 20px;
        }
        .empty-cart i {
            font-size: 60px;
            color: #ccc;
            margin-bottom: 15px;
            display: block;
        }
        .empty-cart h4 {
            color: #86868b !important;
            margin-bottom: 10px;
        }
        .btn-back {
            display: inline-block;
            color: #0052A3;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 15px;
        }
        .btn-back:hover {
            text-decoration: underline;
            color: #003d7a;
        }
        .btn-vaciar {
            background: none;
            border: 1.5px solid #ff3b30;
            color: #ff3b30;
            padding: 8px 16px;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-vaciar:hover {
            background: #ff3b30;
            color: white;
        }
        .cant-items {
            font-size: 0.85rem;
            color: #86868b;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <%- include('partials/navbarUser') %>

    <div class="checkout-container">
        <a href="/cart" class="btn-back">← Volver al catálogo</a>
        <h2 style="font-weight: 800; color: #1d1d1f; margin-bottom: 20px;">🛒 Tu Pedido</h2>

        <div id="checkout-content">
            <!-- Resumen del carrito -->
            <div class="checkout-card">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                    <h4 style="margin-bottom: 0;"><i class="fas fa-box-open"></i> Productos</h4>
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span class="cant-items" id="cant-items"></span>
                        <button class="btn-vaciar" id="btn-vaciar" onclick="vaciarCarrito()" style="display: none;">
                            <i class="fas fa-trash-alt"></i> Vaciar
                        </button>
                    </div>
                </div>
                <div id="cart-items" style="margin-top: 15px;">
                    <div style="text-align: center; padding: 30px;">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p style="margin-top: 10px; color: #86868b;">Cargando carrito...</p>
                    </div>
                </div>
                <div class="total-section" id="total-section" style="display: none;">
                    <div class="total-row">
                        <span>Subtotal:</span>
                        <span id="subtotal">$0</span>
                    </div>
                    <div class="total-row final">
                        <span>Total:</span>
                        <span id="total">$0</span>
                    </div>
                </div>
            </div>

            <!-- Datos del cliente -->
            <div class="checkout-card" id="form-section" style="display: none;">
                <h4><i class="fas fa-user"></i> Tus Datos</h4>
                <form id="checkout-form" onsubmit="return false;">
                    <div class="form-group">
                        <label style="font-weight: 600;">Nombre *</label>
                        <input type="text" class="form-control" id="clienteNombre" placeholder="Tu nombre completo" required>
                    </div>
                    <div class="form-group">
                        <label style="font-weight: 600;">Teléfono *</label>
                        <input type="tel" class="form-control" id="clienteTelefono" placeholder="Ej: 351 123 4567" required>
                    </div>
                    <div class="form-group">
                        <label style="font-weight: 600;">Notas (opcional)</label>
                        <textarea class="form-control" id="notas" rows="2" placeholder="¿Algún detalle adicional?"></textarea>
                    </div>
                </form>

                <button type="button" class="btn-whatsapp" id="btn-finalizar" onclick="finalizarPedido()" style="background: linear-gradient(135deg, var(--metalce-primary), var(--metalce-secondary));">
                    <i class="fas fa-check-circle"></i> Finalizar Pedido
                </button>
                
                <div id="pedido-confirmado" style="display: none; margin-top: 20px; padding: 20px; background: #f5f5f7; border-radius: 12px; text-align: center;">
                    <div style="font-size: 48px; color: #34c759; margin-bottom: 10px;">✅</div>
                    <h3 style="color: #1d1d1f; margin-bottom: 10px;">¡Pedido Registrado!</h3>
                    <p style="color: #86868b; margin-bottom: 5px;">Pedido #<span id="numero-pedido"></span></p>
                    <p style="color: #86868b; margin-bottom: 20px;">Tu pedido ha sido guardado exitosamente</p>
                    <button type="button" class="btn-whatsapp" onclick="enviarPorWhatsApp()" style="width: auto; margin: 0 auto;">
                        <i class="fab fa-whatsapp"></i> Enviar por WhatsApp (Opcional)
                    </button>
                    <br>
                    <a href="/cart" style="display: inline-block; margin-top: 15px; color: var(--metalce-primary); text-decoration: none; font-weight: 600;">
                        <i class="fas fa-arrow-left"></i> Volver al catálogo
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        const PHONE_NUMBER = '<%= phoneNumber %>';
        let carritoData = null;

        // Cargar carrito al iniciar
        async function cargarCarrito() {
            try {
                const response = await fetch('/api/cart');
                const data = await response.json();

                if (data.exito) {
                    carritoData = data.carrito;
                    mostrarCarrito();
                }
            } catch (error) {
                console.error('Error al cargar carrito:', error);
            }
        }

        function mostrarCarrito() {
            const itemsContainer = document.getElementById('cart-items');
            const totalSection = document.getElementById('total-section');
            const formSection = document.getElementById('form-section');
            const cantItems = document.getElementById('cant-items');
            const btnVaciar = document.getElementById('btn-vaciar');
            
            if (!carritoData || carritoData.items.length === 0) {
                itemsContainer.innerHTML = `
                    <div class="empty-cart">
                        <i class="fas fa-shopping-cart"></i>
                        <h4>Tu carrito está vacío</h4>
                        <p style="color: #86868b;">Agregá productos desde el catálogo</p>
                        <a href="/cart" class="btn btn-primary mt-3" style="background: #0052A3; border: none; border-radius: 10px; padding: 10px 24px; color: white; text-decoration: none;">Ver Catálogo</a>
                    </div>
                `;
                totalSection.style.display = 'none';
                formSection.style.display = 'none';
                btnVaciar.style.display = 'none';
                cantItems.textContent = '';
                return;
            }

            btnVaciar.style.display = 'inline-block';
            cantItems.textContent = carritoData.cantidadTotal + ' producto' + (carritoData.cantidadTotal > 1 ? 's' : '');

            itemsContainer.innerHTML = carritoData.items.map(function(item) {
                const subtotal = parseFloat(item.precio_unitario) * item.cantidad;
                return '<div class="product-item" id="item-' + item.id + '">' +
                    '<img src="' + (item.img || '/imgs/placeholder.jpg') + '" alt="' + item.name + '" class="product-img">' +
                    '<div class="product-info">' +
                        '<div class="product-name">' + item.name + '</div>' +
                        '<div class="qty-controls">' +
                            '<button class="qty-btn" onclick="actualizarCantidad(' + item.id + ', ' + (item.cantidad - 1) + ')">−</button>' +
                            '<span class="qty-value">' + item.cantidad + '</span>' +
                            '<button class="qty-btn" onclick="actualizarCantidad(' + item.id + ', ' + (item.cantidad + 1) + ')">+</button>' +
                            '<button class="qty-btn remove" onclick="eliminarItem(' + item.id + ')" title="Eliminar"><i class="fas fa-trash-alt"></i></button>' +
                        '</div>' +
                    '</div>' +
                    '<div class="product-price">$' + subtotal.toLocaleString('es-AR') + '</div>' +
                '</div>';
            }).join('');

            document.getElementById('subtotal').textContent = '$' + carritoData.subtotal.toLocaleString('es-AR');
            document.getElementById('total').textContent = '$' + carritoData.total.toLocaleString('es-AR');
            totalSection.style.display = 'block';
            formSection.style.display = 'block';
        }

        async function actualizarCantidad(itemId, nuevaCantidad) {
            if (nuevaCantidad < 1) {
                eliminarItem(itemId);
                return;
            }
            try {
                const response = await fetch('/api/cart/update/' + itemId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cantidad: nuevaCantidad })
                });
                const data = await response.json();
                if (data.exito) {
                    carritoData = data.carrito;
                    mostrarCarrito();
                } else {
                    alert(data.mensaje);
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        async function eliminarItem(itemId) {
            try {
                const response = await fetch('/api/cart/remove/' + itemId, { method: 'DELETE' });
                const data = await response.json();
                if (data.exito) {
                    carritoData = data.carrito;
                    mostrarCarrito();
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        async function vaciarCarrito() {
            if (!confirm('¿Vaciar todo el carrito?')) return;
            try {
                const response = await fetch('/api/cart/clear', { method: 'DELETE' });
                const data = await response.json();
                if (data.exito) {
                    carritoData = data.carrito;
                    mostrarCarrito();
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        function enviarPorWhatsApp() {
            const nombre = document.getElementById('clienteNombre').value.trim();
            const telefono = document.getElementById('clienteTelefono').value.trim();
            const notas = document.getElementById('notas').value.trim();

            if (!carritoData || carritoData.items.length === 0) {
                alert('El carrito está vacío');
                return;
            }

            // Construir mensaje de WhatsApp
            var mensaje = '🛒 *Nuevo pedido - Metal-Ce*\n\n';
            mensaje += '👤 *Cliente:* ' + nombre + '\n';
            if (telefono) mensaje += '📞 *Teléfono:* ' + telefono + '\n';
            mensaje += '\n📦 *Productos:*\n';
            mensaje += '───────────────\n';

            carritoData.items.forEach(function(item, i) {
                var sub = parseFloat(item.precio_unitario) * item.cantidad;
                mensaje += (i + 1) + '. *' + item.name + '*\n';
                mensaje += '   Cant: ' + item.cantidad + ' × $' + parseFloat(item.precio_unitario).toLocaleString('es-AR') + '\n';
                mensaje += '   Subtotal: $' + sub.toLocaleString('es-AR') + '\n';
            });

            mensaje += '───────────────\n';
            mensaje += '💰 *TOTAL: $' + carritoData.total.toLocaleString('es-AR') + '*\n';
            
            if (notas) {
                mensaje += '\n📝 *Notas:* ' + notas + '\n';
            }

            mensaje += '\n_Enviado desde Metal-Ce_';

            // Abrir WhatsApp
            var whatsappUrl = 'https://wa.me/' + PHONE_NUMBER + '?text=' + encodeURIComponent(mensaje);
            window.open(whatsappUrl, '_blank');
        }

        async function finalizarPedido() {
            const nombre = document.getElementById('clienteNombre').value.trim();
            const telefono = document.getElementById('clienteTelefono').value.trim();
            const notas = document.getElementById('notas').value.trim();

            if (!nombre) {
                document.getElementById('clienteNombre').focus();
                alert('Por favor ingresá tu nombre');
                return;
            }
            if (!telefono) {
                document.getElementById('clienteTelefono').focus();
                alert('Por favor ingresá tu teléfono');
                return;
            }
            if (!carritoData || carritoData.items.length === 0) {
                alert('El carrito está vacío');
                return;
            }

            const btnFinalizar = document.getElementById('btn-finalizar');
            btnFinalizar.disabled = true;
            btnFinalizar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

            try {
                const response = await fetch('/checkout/create-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        cliente_nombre: nombre,
                        cliente_telefono: telefono,
                        notas: notas
                    })
                });

                const data = await response.json();

                if (data.exito) {
                    // Mostrar confirmación
                    document.getElementById('numero-pedido').textContent = data.pedido.numero_pedido;
                    document.getElementById('checkout-form').style.display = 'none';
                    btnFinalizar.style.display = 'none';
                    document.getElementById('pedido-confirmado').style.display = 'block';
                } else {
                    alert('Error al crear el pedido: ' + data.mensaje);
                    btnFinalizar.disabled = false;
                    btnFinalizar.innerHTML = '<i class="fas fa-check-circle"></i> Finalizar Pedido';
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error al procesar el pedido');
                btnFinalizar.disabled = false;
                btnFinalizar.innerHTML = '<i class="fas fa-check-circle"></i> Finalizar Pedido';
            }
        }

        // Cargar carrito al iniciar
        cargarCarrito();
    </script>
</body>
</html>
