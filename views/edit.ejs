<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Producto</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/navBar.css">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/styles.css">

</head>
<body>
    <%- include('partials/navbarUser') %>

    <div class="container">
        <h1 class="text-center catalogo-title">Editar Producto</h1>
        <form action="/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
        
            <div class="form-group">
                <label for="name">Nombre</label>
                <input type="text" class="form-control" id="name" name="name" value="<%= product.name %>" required>
            </div>
           
            <div class="form-group">
                <label for="description">Descripción</label>
                <textarea class="form-control" id="description" name="description" rows="3" required><%= product.description %></textarea>
            </div>
            <div class="form-group">
                <label for="image">Imagen (archivo)</label>
                <input type="file" class="form-control" id="image" name="image" accept="image/*">
                <small id="imageHelp" class="form-text text-muted">Puedes subir un archivo de imagen (JPG, PNG, GIF).</small>
                <img src="<%= product.img %>" alt="Imagen actual" class="img-fluid mt-2">
                <input type="hidden" name="image" value="<%= product.img %>"> <!-- Este campo oculto asegura que la URL de la imagen actual se envíe si no se sube una nueva -->
            </div>
            
            <div class="form-group">
                <label for="price">Precio</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <select class="form-control" id="moneda" name="moneda" style="border-radius: 4px 0 0 4px; min-width: 80px;">
                            <option value="ARS" <%= (product.moneda || 'ARS') === 'ARS' ? 'selected' : '' %>>ARS $</option>
                            <option value="USD" <%= product.moneda === 'USD' ? 'selected' : '' %>>USD $</option>
                        </select>
                    </div>
                    <input type="number" class="form-control" id="price" name="price" value="<%= product.price %>" required>
                </div>
                <small class="form-text text-muted">Moneda actual: <strong><%= product.moneda || 'ARS' %></strong> — Cambiala si necesitás</small>
            </div>
            <div class="form-group">
                <label for="stock">Stock</label>
                <input type="number" class="form-control" id="stock" name="stock" value="<%= product.stock %>" required>
            </div>
            <div class="form-group">
                <label for="categoria_id">Categoría *</label>
                <select class="form-control" id="categoria_id" name="categoria_id" required>
                    <option value="">Selecciona una categoría</option>
                    <% categorias.forEach(categoria => { %>
                        <option value="<%= categoria.id %>" <%= product.categoria_id == categoria.id ? 'selected' : '' %>>
                            <%= categoria.icono %> <%= categoria.nombre %>
                        </option>
                    <% }); %>
                </select>
                <small class="form-text text-muted">
                    ¿No encuentras la categoría? <a href="/categorias" target="_blank">Crear nueva categoría</a>
                </small>
            </div>
            
            <div class="form-group">
                <label for="bateria">Batería (%)</label>
                <input type="number" class="form-control" id="bateria" name="bateria" value="<%= product.bateria || '' %>" min="0" max="100">
                <small class="form-text text-muted">Opcional - Solo para dispositivos con batería</small>
            </div>
            <div class="form-group">
                <label for="almacenamiento">Almacenamiento (GB)</label>
                <input type="number" class="form-control" id="almacenamiento" name="almacenamiento" value="<%= product.almacenamiento || '' %>">
                <small class="form-text text-muted">Opcional - Solo para dispositivos con almacenamiento</small>
            </div>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
            <a href="/" class="btn btn-secondary">Cancelar</a>
        </form>

        <!-- Formulario para eliminar el producto -->
        <form action="/delete/<%= product.id %>" method="POST" style="margin-top: 20px;">
            <button type="submit" class="btn-danger" onclick="return confirm('¿Estás seguro de que deseas eliminar este producto?');">Eliminar Producto</button>
        </form>
    </div>
</body>
</html>
