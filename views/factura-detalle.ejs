<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Factura <%= factura.numero_factura %> - iPhone Stock</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/navBar.css">
    <style>
        .factura-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .factura-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #007bff;
            padding-bottom: 20px;
        }
        .logo-section img {
            max-height: 80px;
        }
        .invoice-info {
            text-align: right;
        }
        .customer-info {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin: 20px 0;
        }
        .items-table {
            margin: 20px 0;
        }
        .items-table th {
            background: #007bff;
            color: white;
            border: none;
        }
        .totals-section {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin-top: 20px;
        }
        .totals-table {
            width: 100%;
            max-width: 300px;
            margin-left: auto;
        }
        .totals-table td {
            padding: 8px 0;
            border: none;
        }
        .total-row {
            font-weight: bold;
            font-size: 18px;
            border-top: 2px solid #007bff;
        }
        .print-button {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
        }
        @media print {
            .print-button, .navbar { display: none; }
            .factura-container { box-shadow: none; }
        }
    </style>
</head>
<body>
    <%- include('partials/navbarUser') %>

    <div class="container mt-4">
        <div class="factura-container" id="facturaContent">
            <!-- Header de la factura -->
            <div class="factura-header">
                <div class="logo-section">
                    <% if (logoUrl) { %>
                        <img src="<%= logoUrl %>" alt="Logo" class="logo">
                    <% } else { %>
                        <h2>iPhone Stock</h2>
                    <% } %>
                </div>
                <div class="invoice-info">
                    <h2 class="text-primary">COMPROBANTE</h2>
                    <p><strong>Número:</strong> <%= factura.numero_factura %></p>
                    <p><strong>Fecha:</strong> <%= new Date(factura.fecha).toLocaleDateString('es-ES') %></p>
                    <p><strong>Estado:</strong> <span class="badge bg-success"><%= factura.estado %></span></p>
                </div>
            </div>

            <!-- Información del cliente -->
            <div class="customer-info">
                <h4>Datos del Cliente</h4>
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Nombre:</strong> <%= factura.cliente_nombre %></p>
                        <% if (factura.cliente_telefono) { %>
                            <p><strong>Teléfono:</strong> <%= factura.cliente_telefono %></p>
                        <% } %>
                    </div>
                    <div class="col-md-6">
                        <% if (factura.cliente_email) { %>
                            <p><strong>Email:</strong> <%= factura.cliente_email %></p>
                        <% } %>
                        <p><strong>Método de Pago:</strong> <%= factura.metodo_pago %></p>
                    </div>
                </div>
            </div>

            <!-- Items de la factura -->
            <div class="items-section">
                <h4>Productos</h4>
                <table class="table table-striped items-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Cantidad</th>
                            <th>Precio Unitario</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <%
                            let items = [];
                            try {
                                // Si items es string, parsearlo. Si es objeto/array, usarlo directamente
                                if (typeof factura.items === 'string') {
                                    items = JSON.parse(factura.items);
                                } else if (Array.isArray(factura.items)) {
                                    items = factura.items;
                                } else if (factura.items && typeof factura.items === 'object') {
                                    items = [factura.items]; // Si es un objeto singular, convertirlo en array
                                }
                            } catch (error) {
                                console.error('Error parsing items:', error);
                                items = [];
                            }
                            
                            items.forEach(item => {
                        %>
                            <tr>
                                <td><%= item.name || 'Producto' %></td>
                                <td><%= item.cantidad || 1 %></td>
                                <td>$<%= parseFloat(item.price || 0).toFixed(2) %></td>
                                <td>$<%= (parseFloat(item.price || 0) * (item.cantidad || 1)).toFixed(2) %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Totales -->
            <div class="totals-section">
                <table class="totals-table">
                    <tr>
                        <td>Subtotal:</td>
                        <td>$<%= parseFloat(factura.subtotal).toFixed(2) %></td>
                    </tr>
                    <tr>
                        <td>Impuestos:</td>
                        <td>$<%= parseFloat(factura.impuestos).toFixed(2) %></td>
                    </tr>
                    <tr class="total-row">
                        <td>TOTAL:</td>
                        <td>$<%= parseFloat(factura.total).toFixed(2) %></td>
                    </tr>
                </table>
            </div>

            <!-- Notas -->
            <% if (factura.notas) { %>
                <div class="notas-section mt-4">
                    <h5>Notas:</h5>
                    <p><%= factura.notas %></p>
                </div>
            <% } %>

            <!-- Información del vendedor -->
            <div class="vendor-info mt-4 text-center">
                <hr>
                <p class="text-muted">
                    <strong>Vendedor:</strong> <%= factura.vendedor_nombre || 'Sistema' %><br>
                    <strong>Fecha de Emisión:</strong> <%= new Date(factura.created_at || factura.fecha).toLocaleString('es-ES') %>
                </p>
                <p class="text-muted">¡Gracias por su compra!</p>
            </div>
        </div>

        <!-- Botones de acción -->
        <div class="text-center mt-4 mb-4">
            <a href="/historico" class="btn btn-secondary me-2">Volver al Histórico</a>
            <a href="/factura/<%= factura.id %>/pdf" class="btn btn-danger me-2" target="_blank">
                Descargar PDF
            </a>
            <button class="btn btn-primary" onclick="imprimirFactura()">
                Imprimir
            </button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function imprimirFactura() {
            window.print();
        }

        // Función para copiar número de factura
        function copiarNumeroFactura() {
            const numeroFactura = '<%= factura.numero_factura %>';
            navigator.clipboard.writeText(numeroFactura).then(() => {
                alert('Número de factura copiado al portapapeles');
            });
        }

        // Agregar evento de teclado para imprimir (Ctrl+P)
        document.addEventListener('keydown', function(e) {
            if (e.ctrlKey && e.key === 'p') {
                e.preventDefault();
                imprimirFactura();
            }
        });
    </script>
</body>
</html>
