    <script>
    async function toggleMantenimiento() {
        const btn = document.getElementById('btn-mantenimiento');
        try {
            const r = await fetch('/admin/toggle-mantenimiento', { method: 'POST' });
            const data = await r.json();
            if (data.ok) {
                const activo = data.modo_mantenimiento;
                btn.textContent = activo ? '✅ Mantenimiento ACTIVO' : '🛠️ Mantenimiento';
                btn.style.background = activo 
                    ? 'linear-gradient(135deg,#8B1538,#A91D47)' 
                    : 'linear-gradient(135deg,#555,#333)';
                alert(activo ? '⚠️ Modo mantenimiento ACTIVADO. El sitio está oculto para usuarios.' : '✅ Modo mantenimiento DESACTIVADO. El sitio es visible.');
            }
        } catch(e) {
            alert('Error al cambiar modo mantenimiento');
        }
    }
    </script>

