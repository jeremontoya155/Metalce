<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sitio en mantenimiento — Metal-Ce S.R.L.</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #1a0008 0%, #6B0F2A 40%, #8B1538 70%, #A91D47 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: white;
            text-align: center;
            padding: 20px;
            overflow: hidden;
        }

        .particles {
            position: fixed; inset: 0; pointer-events: none; z-index: 0;
        }
        .particle {
            position: absolute;
            width: 4px; height: 4px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            animation: float linear infinite;
        }

        @keyframes float {
            from { transform: translateY(110vh) rotate(0deg); opacity: 0; }
            10%  { opacity: 1; }
            90%  { opacity: 1; }
            to   { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
        }

        .content {
            position: relative; z-index: 10;
            max-width: 600px;
            width: 100%;
        }

        .gear-wrapper {
            margin-bottom: 40px;
            position: relative;
            height: 120px;
        }
        .gear-wrapper i:first-child {
            font-size: 6rem;
            color: rgba(255,255,255,0.9);
            animation: spin 4s linear infinite;
            display: inline-block;
        }
        .gear-wrapper i:last-child {
            font-size: 3.5rem;
            color: rgba(255,255,255,0.5);
            animation: spin-reverse 3s linear infinite;
            position: absolute;
            top: 30px; right: calc(50% - 90px);
        }
        @keyframes spin         { to { transform: rotate(360deg);  } }
        @keyframes spin-reverse { to { transform: rotate(-360deg); } }

        .logo-text {
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: 4px;
            text-transform: uppercase;
            opacity: .6;
            margin-bottom: 20px;
        }

        h1 {
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 900;
            margin-bottom: 16px;
            line-height: 1.1;
        }
        h1 span { opacity: .7; }

        p.subtitle {
            font-size: 1.1rem;
            opacity: .8;
            max-width: 420px;
            margin: 0 auto 40px;
            line-height: 1.7;
        }

        .contact-strip {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 16px;
            margin-bottom: 50px;
        }
        .contact-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 50px;
            padding: 10px 20px;
            font-size: .9rem;
            font-weight: 600;
            text-decoration: none;
            color: white;
            transition: background .2s;
        }
        .contact-chip:hover {
            background: rgba(255,255,255,0.22);
            color: white;
            text-decoration: none;
        }

        .back-soon {
            font-size: .8rem;
            opacity: .5;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        @media (max-width: 480px) {
            .gear-wrapper i:last-child { display: none; }
            .contact-strip { flex-direction: column; align-items: center; }
        }
    </style>
</head>
<body>

    <!-- Partículas decorativas -->
    <div class="particles" id="particles"></div>

    <div class="content">
        <div class="logo-text">Metal-Ce S.R.L.</div>

        <div class="gear-wrapper">
            <i class="fas fa-cog"></i>
            <i class="fas fa-cog"></i>
        </div>

        <h1>Sitio en <span>mantenimiento</span></h1>
        <p class="subtitle">
            Estamos realizando mejoras para brindarte una mejor experiencia.
            Volvemos muy pronto — gracias por tu paciencia.
        </p>

        <div class="contact-strip">
            <a href="https://wa.me/5493512345678" class="contact-chip" target="_blank">
                <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
            <a href="mailto:contacto@metalce.com.ar" class="contact-chip">
                <i class="fas fa-envelope"></i> Email
            </a>
            <div class="contact-chip">
                <i class="fas fa-clock"></i> Lun–Vie 8–18
            </div>
        </div>

        <div class="back-soon">Volvemos pronto ✦</div>
    </div>

    <script>
        // Generar partículas flotantes
        const container = document.getElementById('particles');
        for (let i = 0; i < 25; i++) {
            const p = document.createElement('div');
            p.className = 'particle';
            p.style.left = Math.random() * 100 + 'vw';
            p.style.animationDuration = (8 + Math.random() * 12) + 's';
            p.style.animationDelay  = (Math.random() * 10) + 's';
            p.style.width = p.style.height = (2 + Math.random() * 5) + 'px';
            container.appendChild(p);
        }
    </script>
</body>
</html>
