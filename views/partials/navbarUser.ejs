<style>
/* ===== DROPDOWN NAVBAR ===== */
.navbar-menu ul { list-style: none; margin: 0; padding: 0; display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
.navbar-menu ul li { position: relative; }
.navbar-menu ul li a { 
    display: block; padding: 8px 14px; text-decoration: none; color: inherit;
    font-size: .9rem; font-weight: 500; border-radius: 8px; transition: background .2s ease;
    white-space: nowrap;
}
.navbar-menu ul li a:hover { background: rgba(139,21,56,.08); }
.mc-dropdown-toggle { cursor: pointer; user-select: none; }
.mc-dropdown-menu {
    display: none !important;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 12px 40px rgba(0,0,0,.14);
    min-width: 220px;
    z-index: 9999;
    padding: 8px;
    border: 1px solid rgba(0,0,0,.06);
    list-style: none;
}
.mc-dropdown-menu li a { border-radius: 8px; font-size: .88rem; color: #333 !important; padding: 10px 14px; display: block; text-decoration: none; }
.mc-dropdown-menu li a:hover { background: #fdf0f3 !important; color: #8B1538 !important; }
.mc-dropdown-divider { height: 1px; background: #f0f0f0; margin: 6px 0; pointer-events: none; list-style: none; }
.mc-dropdown.open .mc-dropdown-menu { display: block !important; animation: dropFadeIn .18s ease; }
@keyframes dropFadeIn { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:translateY(0); } }
/* Mobile */
@media(max-width: 768px) {
    .mc-dropdown-menu { position: static !important; box-shadow: none; border: none; background: rgba(139,21,56,.05); border-radius: 8px; margin: 4px 0; padding: 4px 0 4px 12px; }
    .mc-dropdown.open .mc-dropdown-menu { display: block !important; }
}
/* Lang toggle */
.mc-lang-btn {
    background: none;
    border: 1.5px solid rgba(139,21,56,.3);
    color: #8B1538;
    border-radius: 50px;
    padding: 5px 12px;
    font-size: .82rem;
    font-weight: 700;
    cursor: pointer;
    transition: background .2s, color .2s;
    letter-spacing: .5px;
}
.mc-lang-btn:hover { background: #8B1538; color: #fff; }
</style>
<script>
    const menuToggle = document.querySelector('.menu-toggle');
    const navbar = document.querySelector('.custom-navbar');

    menuToggle.addEventListener('click', function () {
        this.classList.toggle('active');
        navbar.classList.toggle('active');
    });

    document.addEventListener('click', function (event) {
        if (!navbar.contains(event.target) && !menuToggle.contains(event.target)) {
            menuToggle.classList.remove('active');
            navbar.classList.remove('active');
            document.querySelectorAll('.mc-dropdown.open').forEach(d => d.classList.remove('open'));
        }
    });

    function toggleDropdown(e, el) {
        e.preventDefault();
        e.stopPropagation();
        const li = el.closest('.mc-dropdown');
        const isOpen = li.classList.contains('open');
        document.querySelectorAll('.mc-dropdown.open').forEach(d => d.classList.remove('open'));
        if (!isOpen) li.classList.add('open');
    }

    // ===== i18n EN/ES =====
    const mcTranslations = {
        es: {
            nav_inicio: 'Inicio', nav_catalogo: 'Catálogo', nav_empresa: 'La Empresa ▾',
            nav_quienes: '👥 Quiénes Somos', nav_historia: '📖 Nuestra Historia',
            nav_novedades: '📰 Novedades', nav_verde: '🌿 Línea Verde',
            nav_iso: '🏆 Certificaciones ISO', nav_calidad: '⚙️ Sistema de Calidad',
            nav_contacto: 'Contacto', nav_trabaja: 'Trabajá con nosotros',
            catalogo_title: 'CATÁLOGO', catalogo_sub: 'Encuentra la tecnología perfecta para ti',
            search_placeholder: '🔍 Buscar productos...', filter_catalog: '🗂️ Filtrar catálogo ▾',
            sort_price: '💰 Ordenar por precio', sort_asc: 'Menor a mayor', sort_desc: 'Mayor a menor',
            btn_clear: '✖ Limpiar', all_cats: '✅ Todas las categorías',
            btn_ver_mas: 'Ver más', btn_sin_stock: 'Sin stock', btn_cotizar: '💬 Cotizar',
            footer_contact: 'Contacto', footer_rights: 'Todos los derechos reservados'
        },
        en: {
            nav_inicio: 'Home', nav_catalogo: 'Catalogue', nav_empresa: 'The Company ▾',
            nav_quienes: '👥 About Us', nav_historia: '📖 Our History',
            nav_novedades: '📰 News', nav_verde: '🌿 Green Line',
            nav_iso: '🏆 ISO Certifications', nav_calidad: '⚙️ Quality System',
            nav_contacto: 'Contact', nav_trabaja: 'Work with us',
            catalogo_title: 'CATALOGUE', catalogo_sub: 'Find the perfect technology for you',
            search_placeholder: '🔍 Search products...', filter_catalog: '🗂️ Filter catalogue ▾',
            sort_price: '💰 Sort by price', sort_asc: 'Lowest first', sort_desc: 'Highest first',
            btn_clear: '✖ Clear', all_cats: '✅ All categories',
            btn_ver_mas: 'View more', btn_sin_stock: 'Out of stock', btn_cotizar: '💬 Quote',
            footer_contact: 'Contact', footer_rights: 'All rights reserved'
        }
    };

    function mcApplyLang(lang) {
        const t = mcTranslations[lang] || mcTranslations.es;
        document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (t[key]) el.textContent = t[key];
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
            const key = el.getAttribute('data-i18n-placeholder');
            if (t[key]) el.placeholder = t[key];
        });
        document.querySelectorAll('[data-i18n-html]').forEach(el => {
            const key = el.getAttribute('data-i18n-html');
            if (t[key]) el.innerHTML = t[key];
        });
        const label = document.getElementById('mc-lang-label');
        if (label) label.textContent = lang.toUpperCase();
        document.documentElement.lang = lang;
    }

    function mcToggleLang() {
        const current = localStorage.getItem('mc-lang') || 'es';
        const next = current === 'es' ? 'en' : 'es';
        localStorage.setItem('mc-lang', next);
        mcApplyLang(next);
    }

    // Aplicar idioma guardado al cargar
    (function() {
        const saved = localStorage.getItem('mc-lang') || 'es';
        mcApplyLang(saved);
    })();
</script>