<style>
/* ===== NAVBAR OVERRIDES — white text, consistent everywhere ===== */
.navbar-menu ul { list-style: none; margin: 0; padding: 0; display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
.navbar-menu ul li { position: relative; }
.navbar-menu ul li > a,
.navbar-menu ul li > a:visited {
    display: block; padding: 8px 14px; text-decoration: none;
    color: #fff !important;
    font-size: .9rem; font-weight: 600; border-radius: 8px;
    transition: background .2s ease; white-space: nowrap;
    letter-spacing: .3px;
}
.navbar-menu ul li > a:hover {
    background: rgba(255,255,255,.18) !important;
    color: #fff !important;
}
.mc-dropdown-toggle { cursor: pointer; user-select: none; }

/* Dropdown panel (white bg) — HIDDEN BY DEFAULT */
.mc-dropdown-menu {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    position: absolute; top: calc(100% + 8px); left: 0;
    background: #fff; border-radius: 14px; box-shadow: 0 12px 40px rgba(0,0,0,.14);
    min-width: 220px; z-index: 9999; padding: 8px; border: 1px solid rgba(0,0,0,.06); list-style: none;
    pointer-events: none;
}
/* Force BLACK text in dropdown items — ALWAYS BLACK */
.mc-dropdown-menu li a,
.mc-dropdown-menu li a:visited,
.mc-dropdown-menu li a:hover,
.mc-dropdown-menu li a:active,
.mc-dropdown-menu li a:focus,
.navbar-menu .mc-dropdown-menu li a,
.navbar-menu .mc-dropdown-menu li a:visited,
.navbar-menu .mc-dropdown-menu li a:hover,
.navbar-menu .mc-dropdown-menu li a:active,
.navbar-menu .mc-dropdown-menu li a:focus {
    border-radius: 8px; font-size: .88rem;
    color: #000000 !important;
    padding: 10px 14px; display: block; text-decoration: none; font-weight: 600;
    background: transparent !important;
}
.mc-dropdown-menu li a:hover,
.navbar-menu .mc-dropdown-menu li a:hover { 
    background: #fdf0f3 !important; 
    color: #000000 !important; 
    font-weight: 600 !important;
}
.mc-dropdown-divider { height: 1px; background: #f0f0f0; margin: 6px 0; pointer-events: none; list-style: none; }
.mc-dropdown.open .mc-dropdown-menu {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: auto !important;
    animation: dropFadeIn .18s ease;
}
@keyframes dropFadeIn { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:translateY(0); } }

/* Botón de idioma */
.mc-lang-btn {
    background: none; border: 1.5px solid rgba(255,255,255,.5); color: #fff;
    border-radius: 50px; padding: 5px 12px; font-size: .82rem; font-weight: 700;
    cursor: pointer; transition: background .2s, border-color .2s; letter-spacing: .5px;
    display: flex; align-items: center; gap: 4px;
}
.mc-lang-btn:hover { background: rgba(255,255,255,.15); border-color: rgba(255,255,255,.8); }
.mc-lang-option { opacity: .5; transition: opacity .2s; color: #fff; }
.mc-lang-option.active { opacity: 1; font-weight: 900; }
.mc-lang-separator { opacity: .5; font-weight: 400; color: #fff; }

/* Mobile dropdown */
@media(max-width: 768px) {
    .mc-dropdown-menu {
        position: static !important; box-shadow: none; border: none;
        background: rgba(255,255,255,.1); border-radius: 8px; margin: 4px 0; padding: 4px 0 4px 12px;
    }
    .mc-dropdown.open .mc-dropdown-menu {
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
        pointer-events: auto !important;
    }
    .mc-dropdown-menu li a,
    .mc-dropdown-menu li a:visited { color: rgba(255,255,255,.9) !important; }
    .mc-dropdown-menu li a:hover { background: rgba(255,255,255,.15) !important; color: #fff !important; }
}

/* Lang toggle */
.mc-lang-btn {
    background: rgba(255,255,255,.15); border: 1.5px solid rgba(255,255,255,.4); color: #fff;
    border-radius: 50px; padding: 5px 14px; font-size: .82rem; font-weight: 700;
    cursor: pointer; transition: background .2s, color .2s; letter-spacing: .5px;
}
.mc-lang-btn:hover { background: #fff; color: #8B1538; }
</style>
<script src="/js/translations.js"></script>
<script>
    const menuToggle = document.querySelector('.menu-toggle');
    const navbar = document.querySelector('.custom-navbar');

    menuToggle.addEventListener('click', function () {
        this.classList.toggle('active');
        navbar.classList.toggle('active');
        // Cerrar todos los dropdowns al abrir/cerrar el menú móvil
        document.querySelectorAll('.mc-dropdown.open').forEach(d => d.classList.remove('open'));
    });

    // Cerrar menú móvil y dropdowns al hacer click fuera
    document.addEventListener('click', function (event) {
        const isClickInsideNavbar = navbar.contains(event.target);
        const isClickOnToggle = menuToggle.contains(event.target);
        const isClickOnDropdownToggle = event.target.closest('.mc-dropdown-toggle');
        
        if (!isClickInsideNavbar && !isClickOnToggle) {
            menuToggle.classList.remove('active');
            navbar.classList.remove('active');
            document.querySelectorAll('.mc-dropdown.open').forEach(d => d.classList.remove('open'));
        } else if (isClickInsideNavbar && !isClickOnDropdownToggle) {
            // Si hacemos click dentro del navbar pero NO en un toggle, cerramos los dropdowns
            document.querySelectorAll('.mc-dropdown.open').forEach(d => d.classList.remove('open'));
        }
    });

    function toggleDropdown(e, el) {
        e.preventDefault();
        e.stopPropagation();
        const li = el.closest('.mc-dropdown');
        const isOpen = li.classList.contains('open');
        document.querySelectorAll('.mc-dropdown.open').forEach(d => d.classList.remove('open'));
        if (!isOpen) li.classList.add('open');
    }

    // ===== i18n EN/ES (translations loaded from /js/translations.js) =====
    var mcTranslations = window.mcTranslations || {es:{},en:{}};

    function mcApplyLang(lang) {
        const t = mcTranslations[lang] || mcTranslations.es;
        document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (t[key]) el.textContent = t[key];
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
            const key = el.getAttribute('data-i18n-placeholder');
            if (t[key]) el.placeholder = t[key];
        });
        document.querySelectorAll('[data-i18n-html]').forEach(el => {
            const key = el.getAttribute('data-i18n-html');
            if (t[key]) el.innerHTML = t[key];
        });
        // Actualizar botones de idioma
        const esBtn = document.getElementById('mc-lang-es');
        const enBtn = document.getElementById('mc-lang-en');
        if (esBtn && enBtn) {
            if (lang === 'es') {
                esBtn.classList.add('active');
                enBtn.classList.remove('active');
            } else {
                esBtn.classList.remove('active');
                enBtn.classList.add('active');
            }
        }
        document.documentElement.lang = lang;
    }

    function mcToggleLang() {
        const current = localStorage.getItem('mc-lang') || 'es';
        const next = current === 'es' ? 'en' : 'es';
        localStorage.setItem('mc-lang', next);
        mcApplyLang(next);
    }

    // Aplicar idioma guardado al cargar - DESPUÉS del DOM completo
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            const saved = localStorage.getItem('mc-lang') || 'es';
            mcApplyLang(saved);
        });
    } else {
        const saved = localStorage.getItem('mc-lang') || 'es';
        mcApplyLang(saved);
    }
</script>