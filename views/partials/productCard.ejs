<div class="product-card fade-in-section" 
     data-stock="<%= product.stock %>" 
     data-estado="<%= product.estado || '' %>" 
     data-storage="<%= product.almacenamiento || 0 %>" 
     data-battery="<%= product.bateria || 0 %>" 
     data-model="<%= product.name %>" 
     data-price="<%= product.price %>"
     data-category="<%= product.categoria_id || '' %>"
     data-familia="<%= product.categoria_familia || '' %>"
     data-linea="<%= product.categoria_linea || '' %>"
     data-codigo="<%= product.codigo || '' %>"
     data-toggle="modal" 
     data-target="#productModal<%= product.id %>"
     data-product-id="<%= product.id %>">
  
  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
  <div class="admin-select-overlay" onclick="event.stopPropagation();">
    <input type="checkbox" class="product-select-checkbox" data-product-id="<%= product.id %>" 
           onchange="updateDeleteButton()">
  </div>
  <% } %>

  <% 
    // Verificar si el producto tiene oferta activa
    const tieneOferta = product.tiene_oferta_vigente;
    const precioOriginal = product.price;
    const precioFinal = product.precio_final || product.price;
    const porcentajeDescuento = tieneOferta && product.tipo_descuento === 'porcentaje' ? product.valor_descuento : null;
    const esOfertaGeneral = product.es_oferta_general || false;
    const nombreOfertaGeneral = product.nombre_oferta_general || '';
    
    // Cotización y moneda
    const cotiz = typeof cotizacionDolar !== 'undefined' ? cotizacionDolar : 1200;
    const monedaProd = product.moneda || 'ARS';
    const esUSD = monedaProd === 'USD';
    const simbolo = esUSD ? 'USD' : '$';
  %>

  <% if (tieneOferta) { %>
  <div class="oferta-badge">
    <% if (porcentajeDescuento) { %>
      -<%= porcentajeDescuento %>%
    <% } else { %>
      <span data-i18n="card_offer">OFERTA</span>
    <% } %>
  </div>
  <% } %>

  <div class="product-image-container">
    <img src="<%= product.img %>" alt="<%= product.name %>" class="product-image" loading="lazy" decoding="async" width="400" height="400">
  </div>

  <div class="product-details">
    <% 
    const hasSlash = product.name.includes('/');
    if (hasSlash) {
      const nameParts = product.name.split('/').map(part => part.trim());
    %>
      <div class="product-name-parts">
        <% nameParts.forEach(part => { %>
          <h3 class="product-name-line"><%= part %></h3>
        <% }); %>
      </div>
    <% } else { %>
      <h3 class="product-name"><%= product.name %></h3>
    <% } %>

    <% if (product.codigo) { %>
    <div style="font-size:.78rem;color:#999;font-family:monospace;margin-bottom:4px;letter-spacing:.5px;"><span data-i18n="card_code">Cód:</span> <%= product.codigo %></div>
    <% } %>

    <% if (tieneOferta) { %>
    <div class="precio-container precio-container--oferta">
      <div class="oferta-precios">
        <span class="precio-original"><%= simbolo %> <%= precioOriginal %></span>
        <span class="precio-oferta"><%= simbolo %> <%= precioFinal %></span>
      </div>
      <div class="oferta-meta">
        <span class="ahorro-text"><span data-i18n="card_save">Ahorrás</span> <%= simbolo %> <%= (precioOriginal - precioFinal).toFixed(2) %></span>
        <% if (esOfertaGeneral && nombreOfertaGeneral) { %>
        <span class="oferta-chip"><%= nombreOfertaGeneral %></span>
        <% } else if (!esOfertaGeneral && porcentajeDescuento) { %>
        <span class="oferta-chip"><span data-i18n="card_discount">Desc.</span> <%= porcentajeDescuento %>%</span>
        <% } else if (!esOfertaGeneral) { %>
        <span class="oferta-chip" data-i18n="card_special_offer">Oferta especial</span>
        <% } %>
      </div>
      <% if (esUSD) { %>
      <div class="conversion-hint">
        💱 ARS $<%= Math.round(precioFinal * cotiz).toLocaleString('es-AR') %>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <p class="product-price precio"><%= simbolo %> <%= product.price %></p>
    <% if (esUSD) { %>
    <div class="conversion-hint">
      💱 ARS $<%= Math.round(product.price * cotiz).toLocaleString('es-AR') %>
    </div>
    <% } %>
    <% } %>

    <% 
      // Parsear planes de cuotas
      let planesCard = [];
      try { planesCard = JSON.parse(product.cuotas_planes || '[]'); } catch(e) { planesCard = []; }
      // Fallback al sistema viejo
      if (planesCard.length === 0 && product.cuotas_max && product.cuotas_max > 0) {
        planesCard = [{cuotas: product.cuotas_max, interes: product.interes_cuotas || 0}];
      }
    %>
    <% if (planesCard.length > 0) { %>
    <% 
      // Mostrar el plan con más cuotas — cuotas siempre en ARS
      const mejorPlan = planesCard[planesCard.length - 1];
      const precioBaseCuota = tieneOferta ? precioFinal : product.price;
      const precioBasePesos = esUSD ? (precioBaseCuota * cotiz) : precioBaseCuota;
      const totalCuota = mejorPlan.interes > 0 
        ? (precioBasePesos * (1 + mejorPlan.interes / 100)) 
        : precioBasePesos;
      const valorCuotaCard = Math.round(totalCuota / mejorPlan.cuotas).toLocaleString('es-AR');
      const sinInteres = !mejorPlan.interes || mejorPlan.interes === 0;
    %>
    <div class="cuotas-badge">
      <span class="cuotas-badge__icon">💳</span>
      <span class="cuotas-badge__text">
        <% if (planesCard.length > 1) { %>
          <span data-i18n="card_up_to">Hasta</span> <strong><%= mejorPlan.cuotas %> <span data-i18n="card_installments">cuotas</span></strong> <span data-i18n="card_of">de</span> <strong>$<%= valorCuotaCard %></strong>
        <% } else { %>
          <strong><%= mejorPlan.cuotas %> <span data-i18n="card_installments">cuotas</span></strong> <span data-i18n="card_of">de</span> <strong>$<%= valorCuotaCard %></strong>
        <% } %>
        <% if (sinInteres) { %>
        <span class="cuotas-sin-interes" data-i18n="card_interest_free">sin interés</span>
        <% } %>
      </span>
    </div>
    <% } %>

    <div class="product-footer">
      <% 
        const productNameLower = (product.name || '').toLowerCase();
        const isSmartphone = productNameLower.includes('iphone') || 
                            productNameLower.includes('samsung') || 
                            productNameLower.includes('galaxy') || 
                            productNameLower.includes('xiaomi') || 
                            productNameLower.includes('motorola') ||
                            productNameLower.includes('huawei') ||
                            productNameLower.includes('oppo') ||
                            productNameLower.includes('realme') ||
                            productNameLower.includes('oneplus') ||
                            productNameLower.includes('phone');
        
        const showBattery = product.bateria && product.bateria > 0 && isSmartphone;
      %>
      <% if (showBattery) { %>
      <div class="battery-status">
        <img src="/imgs/bateria.png" alt="Battery Icon" class="battery-icon">
        <p class="bateria">
          <span class="bateria-num"><%= product.bateria %></span>% 
        </p>
      </div>
      <% } %>
      
      <form action="/product" method="POST" class="d-inline" onclick="event.stopPropagation()">
        <input type="hidden" name="productId" value="<%= product.id %>">
        <button type="submit" class="btn-ver-mas-small" data-i18n="btn_ver_mas">Ver más</button>
      </form>
      
      <% if (product.stock > 0) { %>
      <button type="button" class="btn-add-cart-small" onclick="event.stopPropagation(); agregarAlCarrito(<%= product.id %>)">
        <i class="fas fa-shopping-cart"></i>
      </button>
      <% } else { %>
      <span class="badge-sin-stock" data-i18n="btn_sin_stock">Sin stock</span>
      <% } %>
    </div>
  </div>
</div>
